# Environment variables for the eComplete Executive Reporting Dashboard

# Freshdesk API Key (for backend access)
FRESHDESK_API_KEY=

# Freshdesk Proxy URL (if applicable, for backend access)
FRESHDESK_PROXY_URL=

# ReturnGo API Keys (for backend access)
RETURNGO_LEVIS_API_KEY=
RETURNGO_BOUNTY_API_KEY=
RETURNGO_LEVIS_STORE_URL=
RETURNGO_DIESEL_STORE_URL=
RETURNGO_DIESEL_API_KEY=
RETURNGO_HURLEY_STORE_URL=
RETURNGO_HURLEY_API_KEY=
RETURNGO_JEEP_STORE_URL=
RETURNGO_JEEP_API_KEY=
RETURNGO_REEBOK_STORE_URL=
RETURNGO_REEBOK_API_KEY=
RETURNGO_SUPERDRY_STORE_URL=
RETURNGO_SUPERDRY_API_KEY=

# Firebase Service Account Key (JSON string, for backend access)
FIREBASE_SERVICE_ACCOUNT_KEY=


# Google Cloud Storage Bucket Name
GCS_BUCKET_NAME=

# Google Cloud Region
GOOGLE_CLOUD_REGION=us-west1

# Gemini API Key (for frontend and backend access)
GEMINI_API_KEY=

# Parcelninja Credentials (Supports both PARCELNINJA_ and _WAREHOUSE_ naming conventions)
PARCELNINJA_DIESEL_USERNAME=
PARCELNINJA_DIESEL_PASSWORD=
PARCELNINJA_DIESEL_STORE_ID=
DIESEL_WAREHOUSE_API_USERNAME=
DIESEL_WAREHOUSE_API_PASSWORD=
DIESEL_WAREHOUSE_STORE_ID=

PARCELNINJA_HURLEY_USERNAME=
PARCELNINJA_HURLEY_PASSWORD=
PARCELNINJA_HURLEY_STORE_ID=
HURLEY_WAREHOUSE_API_USERNAME=
HURLEY_WAREHOUSE_API_PASSWORD=
HURLEY_WAREHOUSE_STORE_ID=

PARCELNINJA_JEEP_USERNAME=
PARCELNINJA_JEEP_PASSWORD=
PARCELNINJA_JEEP_STORE_ID=
JEEP_APPAREL_WAREHOUSE_API_USERNAME=
JEEP_APPAREL_WAREHOUSE_API_PASSWORD=
JEEP_APPAREL_WAREHOUSE_STORE_ID=

PARCELNINJA_SUPERDRY_USERNAME=
PARCELNINJA_SUPERDRY_PASSWORD=
PARCELNINJA_SUPERDRY_STORE_ID=
SUPERDRY_WAREHOUSE_API_USERNAME=
SUPERDRY_WAREHOUSE_API_PASSWORD=
SUPERDRY_WAREHOUSE_STORE_ID=

